# KDE Plasma service menu — adds "Help me rewrite" to Dolphin's right-click menu
# for text files.
#
# Install to: ~/.local/share/kio/servicemenus/
# Then restart Dolphin or log out/in.
#
# Note: This menu entry applies to file-manager context menus.  For in-app text
# selection, use the keyboard shortcut registered by install.sh instead.

[Desktop Entry]
Type=Service
ServiceTypes=KonqPopupMenu/Plugin
MimeType=text/plain;text/markdown;text/html;text/csv;
Actions=RewriteGrammar;RewriteFormal;RewriteConcise;

[Desktop Action RewriteGrammar]
Name=Help me rewrite (fix grammar)
Icon=accessories-text-editor
Exec=rewrite-it-selection grammar %f

[Desktop Action RewriteFormal]
Name=Help me rewrite (formal)
Icon=accessories-text-editor
Exec=rewrite-it-selection formal %f

[Desktop Action RewriteConcise]
Name=Help me rewrite (concise)
Icon=accessories-text-editor
Exec=rewrite-it-selection concise %f
